{
  "schema": {
    "type": "object",
    "properties": {
      "review_outcome": {
        "type": "string",
        "title": "Application Assessment Outcome",
        "oneOf": [
          { "const": "approve", "title": "Approve" },
          { "const": "reject", "title": "Reject" },
          { "const": "needs_more_info", "title": "Request More Info" }
        ]
      },
      "reference_number": {
        "type": "string",
        "title": "FCAU Application Reference Number"
      },
      "rejection_reason": {
        "type": "string",
        "title": "Comments / Feedback / Deficiencies (if Reject/Needs Info)"
      }
    },
    "required": ["review_outcome"],
    "if": {
      "properties": { "review_outcome": { "const": "approve" } }
    },
    "then": {
      "required": ["reference_number"]
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/review_outcome" },
      {
        "type": "Control",
        "scope": "#/properties/reference_number",
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "const": "approve" }
          }
        }
      },
      {
        "type": "Control",
        "scope": "#/properties/rejection_reason",
        "options": { "multi": true },
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "enum": ["reject", "needs_more_info"] }
          }
        }
      }
    ]
  }
}