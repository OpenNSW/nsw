{
    "schema": {
        "type": "object",
        "properties": {
            "review_outcome": {
                "type": "string",
                "title": "Review Outcome",
                "oneOf": [
                    { "const": "approve", "title": "Approve" },
                    { "const": "reject", "title": "Reject" },
                    { "const": "needs_more_info", "title": "Request More Info" }
                ]
            },
            "applicationId": {
                "type": "string",
                "title": "FCAU Reference ID",
                "description": "Please enter the internal FCAU reference ID"
            },
            "rejection_reason": {
                "type": "string",
                "title": "Reason / Comments"
            }
        },
        "required": ["review_outcome"],
        "if": {
            "properties": { "review_outcome": { "const": "approve" } }
        },
        "then": {
            "required": ["applicationId"]
        }
    },
    "uiSchema": {
        "type": "VerticalLayout",
        "elements": [
            { "type": "Control", "scope": "#/properties/review_outcome" },
            {
                "type": "Control",
                "scope": "#/properties/applicationId",
                "rule": {
                    "effect": "SHOW",
                    "condition": {
                        "scope": "#/properties/review_outcome",
                        "schema": { "const": "approve" }
                    }
                }
            },
            {
                "type": "Control",
                "scope": "#/properties/rejection_reason",
                "options": { "multi": true },
                "rule": {
                    "effect": "SHOW",
                    "condition": {
                        "scope": "#/properties/review_outcome",
                        "schema": { "enum": ["reject", "needs_more_info"] }
                    }
                }
            }
        ]
    }
}