{
  "schema": {
    "type": "object",
    "properties": {
      "review_outcome": {
        "type": "string",
        "title": "Review Outcome",
        "oneOf": [
          { "const": "approve", "title": "Approve" },
          { "const": "reject", "title": "Reject" },
          { "const": "needs_more_info", "title": "Request More Info" }
        ]
      },
      "doc_review_result": {
        "type": "string",
        "title": "Document Review Result",
        "oneOf": [
          { "const": "approve", "title": "Approve" },
          { "const": "reject", "title": "Reject" }
        ]
      },
      "rejection_reason": {
        "type": "string",
        "title": "Reason / Comments"
      }
    },
    "required": ["review_outcome", "doc_review_result"]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/review_outcome" },
      { "type": "Control", "scope": "#/properties/doc_review_result" },
      {
        "type": "Control",
        "scope": "#/properties/rejection_reason",
        "options": { "multi": true },
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "enum": ["reject", "needs_more_info"] }
          }
        }
      }
    ]
  }
}
