{
  "schema": {
    "type": "object",
    "properties": {
      "review_outcome": {
        "type": "string",
        "title": "Review Outcome",
        "oneOf": [
          { "const": "approve", "title": "Approve" },
          { "const": "reject", "title": "Reject" },
          { "const": "needs_more_info", "title": "Request More Info" }
        ]
      },
      "reference_number": {
        "type": "string",
        "title": "Reference Number"
      },
      "sample_required": {
        "type": "string",
        "title": "Sample Testing Required?",
        "enum": ["no", "yes"]
      },
      "fumigation_required": {
        "type": "string",
        "title": "Fumigation Treatment Required?",
        "enum": ["no", "yes"]
      },
      "rejection_reason": {
        "type": "string",
        "title": "Reason / Comments"
      }
    },
    "required": ["review_outcome"],
    "if": {
      "properties": { "review_outcome": { "const": "approve" } }
    },
    "then": {
      "required": ["reference_number", "sample_required", "fumigation_required"]
    }
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/review_outcome" },
      {
        "type": "Control",
        "scope": "#/properties/reference_number",
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "const": "approve" }
          }
        }
      },
      {
        "type": "Control",
        "scope": "#/properties/sample_required",
        "options": {
          "format": "radio"
        },
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "const": "approve" }
          }
        }
      },
      {
        "type": "Control",
        "scope": "#/properties/fumigation_required",
        "options": {
          "format": "radio"
        },
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "const": "approve" }
          }
        }
      },
      {
        "type": "Control",
        "scope": "#/properties/rejection_reason",
        "options": { "multi": true },
        "rule": {
          "effect": "SHOW",
          "condition": {
            "scope": "#/properties/review_outcome",
            "schema": { "enum": ["reject", "needs_more_info"] }
          }
        }
      }
    ]
  }
}