{
  "schema": {
    "type": "object",
    "properties": {
      "lab_result": {
        "type": "string",
        "title": "Laboratory Test Result",
        "oneOf": [
          { "const": "pass", "title": "Pass" },
          { "const": "fail", "title": "Fail" }
        ]
      },
      "remarks": {
        "type": "string",
        "title": "Remarks / Findings"
      }
    },
    "required": ["lab_result"]
  },
  "uiSchema": {
    "type": "VerticalLayout",
    "elements": [
      { "type": "Control", "scope": "#/properties/lab_result" },
      {
        "type": "Control",
        "scope": "#/properties/remarks",
        "options": { "multi": true }
      }
    ]
  }
}