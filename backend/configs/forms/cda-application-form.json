{
	"id": "cda-application-form",
	"name": "CDA Application Form",
	"description": "Form for applicants to submit their application for the CDA process.",
	"schema": {
		"type": "object",
		"properties": {
			"paymentDetails": {
				"type": "string",
				"title": "Upload Payment Details",
				"format": "file",
				"example": "payment_details.pdf"
			},
			"paymentCategory": {
				"type": "string",
				"enum": ["General", "SVAT", "Value Added DC/ LAW FAT"],
				"description": "Payment Category",
				"example": "General"
			},
			"exporterNameAddressReg": {
				"type": "string",
				"enum": ["Exporter A", "Exporter B"],
				"description": "Exporter Name, Address & Registration Number",
				"example": "Exporter A"
			},
			"paymentSlip": {
				"type": "string",
				"title": "Upload Payment Slip",
				"format": "file",
				"example": "payment_slip.pdf"
			},
			"contactNumber": {
				"type": "number",
				"description": "Contact Number",
				"example": 94771234567
			},
			"cusdecNumber": {
				"type": "string",
				"description": "CUSDEC Number",
				"example": "CUSDEC123456"
			},
			"hsCode": {
				"type": "number",
				"description": "HS CODE",
				"example": 120300
			},
			"contractNumber": {
				"type": "number",
				"description": "Contract Number",
				"example": 987654
			},
			"lotNumber": {
				"type": "number",
				"description": "Lot Number",
				"example": 12345
			},
			"dcGrade": {
				"title": "DC Grade",
				"description": "DC Grade",
				"type": "array",
				"items": {
					"type": "string",
					"enum": ["FINE", "MEDIUM", "COARSE"]
				},
				"uniqueItems": true,
				"example": ["FINE", "MEDIUM"]
			},
			"numberOfBags": {
				"type": "number",
				"description": "Number of Bags",
				"example": 100
			},
			"weightOfBag": {
				"type": "number",
				"description": "Weight of a Bag",
				"example": 25
			},
			"totalWeight": {
				"type": "number",
				"description": "Total Weight",
				"example": 2500
			},
			"dateOfContainerization": {
				"type": "string",
				"format": "date",
				"description": "Date of Containerization",
				"example": "2026-04-01"
			},
			"nameOfVessel": {
				"type": "string",
				"description": "Name of the Vessel",
				"example": "MV Ocean Star"
			},
			"containerNumber": {
				"type": "string",
				"description": "Container Number",
				"example": "CONT1234567"
			},
			"dateOfSailing": {
				"type": "string",
				"format": "date",
				"description": "Date of Sailing",
				"example": "2026-04-05"
			},
			"portOfDischarge": {
				"type": "string",
				"description": "Port of Discharge",
				"example": "Port of Singapore"
			},
			"finalDestination": {
				"type": "string",
				"description": "Final Destination",
				"example": "Singapore"
			},
			"nameOfBuyer": {
				"type": "string",
				"description": "Name of the Buyer",
				"example": "ABC Imports Ltd"
			},
			"containerFillingStatus": {
				"type": "string",
				"enum": ["Full", "Part"],
				"description": "Container Filling Status",
				"example": "Full"
			},
			"balanceMaterialNature": {
				"type": "string",
				"description": "If Part, Declare Nature of Balance Material",
				"example": "Tea leaves"
			},
			"requiredCertificates": {
				"type": "array",
				"title": "pick all certificates that are being requested",
				"description": "pick all certificates that are being requested",
				"items": {
					"type": "string",
					"enum": ["SALMONELLA", "QUALITY CERTIFICATE"]
				},
				"uniqueItems": true,
				"example": ["SALMONELLA"]
			},
			"detailsOfBags": {
				"type": "string",
				"title": "Upload Details of Bags (Please Fill Google Sheet sent with this Form)",
				"format": "file",
				"example": "bag_details.xlsx"
			}
		},
		"required": [
			"paymentDetails",
			"paymentCategory",
			"exporterNameAddressReg",
			"paymentSlip",
			"contactNumber",
			"cusdecNumber",
			"dcGrade",
			"numberOfBags",
			"weightOfBag",
			"totalWeight",
			"portOfDischarge",
			"finalDestination",
			"containerFillingStatus",
			"detailsOfBags"
		]
	},
	"uiSchema": {
		"type": "Categorization",
		"elements": [
			{
				"type": "Category",
				"label": "General",
				"elements": [
					{
						"type": "Control",
						"scope": "#/properties/contactNumber"
					},
					{
						"type": "Control",
						"scope": "#/properties/contractNumber"
					}
				]
			},
			{
				"type": "Category",
				"label": "Consignment",
				"elements": [
					{
						"type": "Control",
						"scope": "#/properties/exporterNameAddressReg"
					},
					{
						"type": "Control",
						"scope": "#/properties/cusdecNumber"
					},
					{
						"type": "Control",
						"scope": "#/properties/hsCode"
					},
					{
						"type": "Control",
						"scope": "#/properties/lotNumber"
					},
					{
						"type": "Control",
						"scope": "#/properties/dcGrade"
					},
					{
						"type": "Control",
						"scope": "#/properties/numberOfBags"
					},
					{
						"type": "Control",
						"scope": "#/properties/weightOfBag"
					},
					{
						"type": "Control",
						"scope": "#/properties/totalWeight"
					},
					{
						"type": "Control",
						"scope": "#/properties/dateOfContainerization"
					},
					{
						"type": "Control",
						"scope": "#/properties/nameOfVessel"
					},
					{
						"type": "Control",
						"scope": "#/properties/containerNumber"
					},
					{
						"type": "Control",
						"scope": "#/properties/dateOfSailing"
					},
					{
						"type": "Control",
						"scope": "#/properties/portOfDischarge"
					},
					{
						"type": "Control",
						"scope": "#/properties/finalDestination"
					},
					{
						"type": "Control",
						"scope": "#/properties/nameOfBuyer"
					},
					{
						"type": "Control",
						"scope": "#/properties/containerFillingStatus",
						"options": {
							"format": "radio"
						}
					},
					{
						"type": "Control",
						"scope": "#/properties/balanceMaterialNature",
						"options": {
							"multi": true
						}
					},
					{
						"type": "Control",
						"scope": "#/properties/requiredCertificates",
						"label": "pick all certificates that are being requested"
					},
					{
						"type": "VerticalLayout",
						"elements": [
							{
								"text": "Uploaded Details of Bags",
								"type": "Label"
							},
							{
								"type": "Control",
								"scope": "#/properties/detailsOfBags"
							}
						]
					}
				]
			},
			{
				"type": "Category",
				"label": "Finance",
				"elements": [
					{
						"type": "Control",
						"scope": "#/properties/paymentCategory",
						"options": {
							"format": "radio"
						}
					}
				]
			}
		]
	},
	"version": "1.0",
	"active": true
}
