{
	"id": "fcau-application-form",
	"name": "FCAU Application Form",
	"description": "Form for applicants to submit their application for the FCAU process.",
	"schema": {
		"type": "object",
		"properties": {
			"nameOfApplicant": {
				"type": "string",
				"title": "Name of Applicant",
				"example": "ABC Exports Pvt Ltd"
			},
			"addressOfApplicant": {
				"type": "string",
				"title": "Address of Applicant",
				"example": "No. 123, Galle Road, Colombo 03, Sri Lanka"
			},
			"nameOfConsignee": {
				"type": "string",
				"title": "Name of Consignee",
				"example": "XYZ Imports Ltd"
			},
			"addressOfConsignee": {
				"type": "string",
				"title": "Address of Consignee",
				"example": "45 Marina Bay Street, Singapore"
			},
			"descriptionOfConsignment": {
				"type": "string",
				"title": "Description of consignment and quantity",
				"example": "Desiccated Coconut - 1000 bags (25kg each)"
			},
			"dateOfIntendedExport": {
				"type": "string",
				"format": "date",
				"title": "Date of intended export",
				"example": "2026-04-15"
			},
			"lcNo": {
				"type": "string",
				"title": "L/C No",
				"example": "LC-2026-789456"
			},
			"containerNumbers": {
				"type": "string",
				"title": "Upload Container Numbers",
				"format": "file",
				"example": "container_numbers.xlsx"
			},
			"nameOfVessel": {
				"type": "string",
				"title": "Name of Vessel/ Number",
				"example": "MV Ocean Star 1234"
			},
			"addressConsignmentStored": {
				"type": "string",
				"title": "Address where consignment is stored",
				"example": "Warehouse No. 5, Colombo Port, Sri Lanka"
			},
			"packageDetails": {
				"type": "string",
				"title": "Type of Package, Batch Codes and Total weight",
				"example": "Polypropylene bags, Batch No: DC2026-01, Total weight: 25,000 kg"
			},
			"ingredientDetails": {
				"type": "string",
				"title": "Upload or Enter Details of ingredients used in product",
				"format": "file",
				"example": "ingredient_details.pdf"
			},
			"qualityMonitoringDetails": {
				"type": "string",
				"title": "Details of in-house quality monitoring",
				"example": "Daily microbial testing and moisture level checks conducted"
			},
			"analysisCertificates": {
				"type": "string",
				"title": "Upload Raw materials and product analysis certificates",
				"format": "file",
				"example": "analysis_certificates.pdf"
			},
			"otherDeclarations": {
				"type": "string",
				"title": "Any other Declarations",
				"example": "All products comply with international export standards"
			}
		},
		"required": [
			"nameOfApplicant",
			"addressOfApplicant",
			"nameOfConsignee",
			"addressOfConsignee",
			"descriptionOfConsignment",
			"dateOfIntendedExport",
			"lcNo",
			"containerNumbers",
			"nameOfVessel",
			"addressConsignmentStored",
			"packageDetails",
			"ingredientDetails",
			"qualityMonitoringDetails",
			"analysisCertificates"
		]
	},
	"uiSchema": {
		"type": "Categorization",
		"elements": [
			{
				"type": "Category",
				"label": "Consignment",
				"elements": [
					{
						"type": "Control",
						"scope": "#/properties/nameOfApplicant"
					},
					{
						"type": "Control",
						"scope": "#/properties/addressOfApplicant"
					},
					{
						"type": "Control",
						"scope": "#/properties/nameOfConsignee"
					},
					{
						"type": "Control",
						"scope": "#/properties/addressOfConsignee"
					},
					{
						"type": "Control",
						"scope": "#/properties/dateOfIntendedExport"
					},
					{
						"type": "Control",
						"scope": "#/properties/lcNo"
					},
					{
						"type": "VerticalLayout",
						"elements": [
							{
								"text": "Container Numbers (attach list if necessary)",
								"type": "Label"
							},
							{
								"type": "Control",
								"scope": "#/properties/containerNumbers"
							}
						]
					}
				]
			},
			{
				"type": "Category",
				"label": "Transport",
				"elements": [
					{
						"type": "Control",
						"scope": "#/properties/nameOfVessel"
					}
				]
			},
			{
				"type": "Category",
				"label": "Items",
				"elements": [
					{
						"type": "Control",
						"scope": "#/properties/descriptionOfConsignment"
					},
					{
						"type": "Control",
						"scope": "#/properties/addressConsignmentStored"
					},
					{
						"type": "Control",
						"scope": "#/properties/packageDetails"
					},
					{
						"type": "VerticalLayout",
						"elements": [
							{
								"text": "Details of ingredients used in product",
								"type": "Label"
							},
							{
								"type": "Control",
								"scope": "#/properties/ingredientDetails"
							}
						]
					},
					{
						"type": "Control",
						"scope": "#/properties/qualityMonitoringDetails",
						"options": {
							"multi": true
						}
					},
					{
						"type": "VerticalLayout",
						"elements": [
							{
								"text": "Raw materials and product analysis certificates (Attach)",
								"type": "Label"
							},
							{
								"type": "Control",
								"scope": "#/properties/analysisCertificates"
							}
						]
					},
					{
						"type": "Control",
						"scope": "#/properties/otherDeclarations",
						"options": {
							"multi": true
						}
					}
				]
			}
		]
	},
	"version": "1.0",
	"active": true
}
